//Borůvka’s Algorithm
#include <iostream>
using namespace std;

#define V 4
#define E 5

struct Edge {
    int src, dest, weight;
};

int find(int parent[], int i) {
    return (parent[i] == i) ? i : find(parent, parent[i]);
}

void Union(int parent[], int x, int y) {
    parent[find(parent, x)] = find(parent, y);
}

void boruvka(Edge edges[]) {
    int parent[V], mstWeight = 0, trees = V;

    for (int i = 0; i < V; i++) parent[i] = i;

    while (trees > 1) {
        int cheapest[V];
        for (int i = 0; i < V; i++) cheapest[i] = -1;

        for (int i = 0; i < E; i++) {
            int a = find(parent, edges[i].src);
            int b = find(parent, edges[i].dest);

            if (a != b) {
                if (cheapest[a] == -1 || edges[i].weight < edges[cheapest[a]].weight)
                    cheapest[a] = i;
                if (cheapest[b] == -1 || edges[i].weight < edges[cheapest[b]].weight)
                    cheapest[b] = i;
            }
        }

        for (int i = 0; i < V; i++) {
            if (cheapest[i] != -1) {
                int a = find(parent, edges[cheapest[i]].src);
                int b = find(parent, edges[cheapest[i]].dest);

                if (a != b) {
                    mstWeight += edges[cheapest[i]].weight;
                    Union(parent, a, b);
                    trees--;
                }
            }
        }
    }

    cout << "MST Weight: " << mstWeight;
}

int main() {
    Edge edges[E] = {
        {0,1,10}, {0,2,6}, {0,3,5}, {1,3,15}, {2,3,4}
    };

    boruvka(edges);
}
